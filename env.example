# Django Backend Environment Variables
# Copy this file to .env and fill in your actual values

# Django Settings
DEBUG=True
DJANGO_SECRET_KEY=your-secret-key-here-generate-a-long-random-string
ALLOWED_HOSTS=localhost,127.0.0.1

# Database (Leave empty for SQLite in development, Render auto-sets in production)
DATABASE_URL=

# Frontend URL for CORS (Production only)
FRONTEND_URL=https://your-frontend.vercel.app

# SportMonks API (Get from https://www.sportmonks.com/)
SPORTMONKS_TOKEN=your-sportmonks-api-token-here
SPORTMONKS_API_TOKEN=your-sportmonks-api-token-here

# Email Configuration (Optional - for future use)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
EMAIL_USE_TLS=True

# Redis (Optional - for caching, if needed later)
REDIS_URL=redis://localhost:6379/0


# Marketing Automation (Optional)
MARKETING_SYNC_ENABLED=False
MARKETING_SYNC_WEBHOOK_URL=
MARKETING_SYNC_TOKEN=
MARKETING_WEBHOOK_SECRET=
MARKETING_TRACK_RECORD_URL=https://betglitch.com/track-record
MARKETING_PRICING_URL=https://betglitch.com/pricing

# Brevo Integration (Optional)
BREVO_API_KEY=
BREVO_SENDER_EMAIL=
BREVO_SENDER_NAME=SmartBet
BREVO_WELCOME_EMAIL_ENABLED=False
BREVO_WELCOME_TEMPLATE_ID=
BREVO_SANDBOX_MODE=True
BREVO_DEFAULT_LIST_IDS=
BREVO_PAID_LIST_IDS=
BREVO_ATTRIBUTE_SOURCE=
BREVO_ATTRIBUTE_LANDING_PAGE=
BREVO_ATTRIBUTE_UTM_SOURCE=
BREVO_ATTRIBUTE_UTM_MEDIUM=
BREVO_ATTRIBUTE_UTM_CAMPAIGN=
BREVO_ATTRIBUTE_LANGUAGE=
BREVO_ATTRIBUTE_LEAGUE_INTEREST=
